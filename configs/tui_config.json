{
  "theme": "dark",
  "language": "en",
  "auto_save": true,
  "notifications": true,
  "default_agent": "general",
  "default_model": "qwen3:14b",
  "max_iterations": "50",
  "timeout_seconds": 300,
  "auto_retry": true,
  "ws_url": "ws://localhost:8765/ws",
  "ws_reconnect": true,
  "ws_reconnect_interval": 5,
  "show_timestamps": true,
  "show_tokens": true,
  "auto_scroll": true,
  "compact_mode": false,
  "update_interval": "2.0",
  "log_level": "info",
  "cache_enabled": true
}

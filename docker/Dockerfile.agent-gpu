# Dockerfile pour Agent MPtoO avec GPU ROCm
# Intégration complète GPU pour les agents

FROM ubuntu:24.04

# Environment variables for ROCm
ENV ROCM_PATH=/opt/rocm
ENV HIP_PLATFORM=amd
ENV HSA_OVERRIDE_GFX_VERSION=11.0.0
ENV PYTORCH_ROCM_ARCH=gfx1100
ENV PATH=$ROCM_PATH/bin:$PATH
ENV LD_LIBRARY_PATH=$ROCM_PATH/lib:$LD_LIBRARY_PATH
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    wget \
    curl \
    vim \
    build-essential \
    gnupg2 \
    ca-certificates \
    software-properties-common \
    python3.12 \
    python3.12-dev \
    python3.12-venv \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Add ROCm GPG key and repository
RUN mkdir -p /etc/apt/keyrings && \
    wget -q -O - https://repo.radeon.com/rocm/rocm.gpg.key | gpg --dearmor -o /etc/apt/keyrings/rocm.gpg && \
    echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/rocm.gpg] https://repo.radeon.com/rocm/apt/7.1 jammy main" > /etc/apt/sources.list.d/rocm.list && \
    echo 'Package: *' > /etc/apt/preferences.d/rocm-pin-600 && \
    echo 'Pin: release o=repo.radeon.com' >> /etc/apt/preferences.d/rocm-pin-600 && \
    echo 'Pin-Priority: 600' >> /etc/apt/preferences.d/rocm-pin-600

# Install ROCm 7.1
RUN apt-get update && \
    apt-get install -y rocm-hip-sdk rocm-smi-lib && \
    rm -rf /var/lib/apt/lists/*

# Create Python virtual environment
RUN python3.12 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Upgrade pip
RUN pip install --upgrade pip setuptools wheel

# Install PyTorch with ROCm support
RUN pip install --no-cache-dir \
    torch==2.7.0 \
    torchvision==0.22.0 \
    torchaudio==2.7.0 \
    --index-url https://download.pytorch.org/whl/rocm6.3

# Install ML and agent dependencies
RUN pip install --no-cache-dir \
    transformers \
    datasets \
    accelerate \
    peft \
    trl \
    requests \
    httpx \
    pydantic \
    loguru \
    rich \
    typer \
    numpy \
    pandas \
    scipy \
    scikit-learn

# Install browser automation
RUN pip install --no-cache-dir \
    playwright \
    selenium \
    webdriver-manager

# Install OpenManus dependencies
RUN pip install --no-cache-dir \
    beautifulsoup4 \
    lxml \
    pillow \
    opencv-python \
    matplotlib \
    seaborn

# Create symlink for python
RUN ln -s /opt/venv/bin/python /usr/local/bin/python

# Create directories
RUN mkdir -p /app/src /app/configs /app/output /app/logs

# Copy application code
COPY src/ /app/src/
COPY pyproject.toml /app/
COPY requirements.txt /app/

# Install additional requirements
RUN pip install -r /app/requirements.txt

# Create GPU configuration
RUN cat > /app/gpu_config.py << 'EOF'
"""Configuration GPU pour l'agent."""

import torch
import os

# GPU Configuration
GPU_CONFIG = {
    "enabled": os.getenv("GPU_ENABLED", "true").lower() == "true",
    "device": os.getenv("GPU_DEVICE", "cuda:0"),
    "memory_fraction": float(os.getenv("GPU_MEMORY_FRACTION", "0.8")),
    "ollama_host": os.getenv("OLLAMA_HOST", "http://localhost:11434"),
    "max_workers": int(os.getenv("MAX_GPU_WORKERS", "4"))
}

def setup_gpu():
    """Configure le GPU pour l'agent."""
    if GPU_CONFIG["enabled"] and torch.cuda.is_available():
        device = torch.device(GPU_CONFIG["device"])
        torch.cuda.set_device(device)

        # Configure memory
        torch.cuda.set_per_process_memory_fraction(GPU_CONFIG["memory_fraction"])

        print(f"🚀 GPU activé: {torch.cuda.get_device_name(device)}")
        print(f"📊 Mémoire GPU: {torch.cuda.get_device_properties(device).total_memory / 1024**3:.1f} GB")
        return device
    else:
        print("⚠️  GPU désactivé ou non disponible - utilisation CPU")
        return torch.device("cpu")

def get_gpu_info():
    """Retourne les informations GPU."""
    if torch.cuda.is_available():
        info = {
            "count": torch.cuda.device_count(),
            "current_device": torch.cuda.current_device(),
            "devices": []
        }

        for i in range(torch.cuda.device_count()):
            info["devices"].append({
                "id": i,
                "name": torch.cuda.get_device_name(i),
                "memory_total": torch.cuda.get_device_properties(i).total_memory,
                "memory_allocated": torch.cuda.memory_allocated(i),
                "memory_free": torch.cuda.get_device_properties(i).total_memory - torch.cuda.memory_allocated(i)
            })

        return info
    else:
        return {"count": 0, "devices": []}
EOF

# Create entry point
RUN cat > /app/start_agent.py << 'EOF'
#!/usr/bin/env python3
"""Point d'entrée pour l'agent GPU."""

import sys
sys.path.insert(0, '/app')

from gpu_config import setup_gpu, get_gpu_info
from loguru import logger

def main():
    """Démarre l'agent avec GPU."""
    logger.info("🚀 Démarrage de l'agent MPtoO avec GPU")

    # Configuration GPU
    device = setup_gpu()
    gpu_info = get_gpu_info()

    logger.info(f"📊 Informations GPU: {gpu_info}")

    # Ici vous importeriez et lanceriez votre agent
    # from src.agents.main import Agent
    # agent = Agent(device=device)
    # agent.run()

    logger.info(f"✅ Agent configuré avec device: {device}")

    # Garder le conteneur actif
    try:
        import time
        while True:
            time.sleep(60)
            logger.info("💓 Agent actif...")
    except KeyboardInterrupt:
        logger.info("👋 Arrêt de l'agent")

if __name__ == "__main__":
    main()
EOF

RUN chmod +x /app/start_agent.py

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD python3 -c "import torch; print(f'GPU: {torch.cuda.is_available()}')" || exit 1

# Default command
CMD ["python3", "/app/start_agent.py"]

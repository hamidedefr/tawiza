# Dockerfile for Streamlit apps
FROM python:3.12-slim

# Build argument for app selection
ARG APP_NAME=evaluator
ENV APP_NAME=${APP_NAME}

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Install dependencies for Streamlit + evaluation agents + advanced search
RUN pip install --no-cache-dir \
    streamlit>=1.30.0 \
    httpx>=0.27.0 \
    pydantic>=2.0.0 \
    pydantic-settings>=2.0.0 \
    python-dotenv>=1.0.0 \
    psutil>=5.9.0 \
    ollama>=0.6.0 \
    pandas>=2.2.0 \
    plotly>=5.18.0 \
    watchdog>=3.0.0 \
    loguru>=0.7.0 \
    qdrant-client>=1.7.0 \
    redis>=5.0.0 \
    aiofiles>=23.0.0 \
    beautifulsoup4>=4.12.0 \
    lxml>=5.0.0

# Copy source and app code
COPY src/ ./src/
COPY app/ ./app/

# Note: Running as root for simplicity. For production, configure proper permissions.

# Environment
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV STREAMLIT_SERVER_PORT=8501
ENV STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Expose port
EXPOSE 8501

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import httpx; httpx.get('http://localhost:8501/_stcore/health')" || exit 1

# Run the appropriate app
CMD streamlit run app/${APP_NAME}/main.py --server.port=8501 --server.address=0.0.0.0
